<Window x:Class="SimpleWebcam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Webcam"
        Width="1180"
        Height="790"
        MinWidth="980"
        MinHeight="700"
        Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="#DB2777" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="FeatureText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DB2777" Padding="28,24">
            <StackPanel>
                <TextBlock Text="Simple Webcam" Foreground="White" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Capture local snapshots and manage webcam output locally." Foreground="#E0F2FE" FontSize="16" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Live Capture" FontSize="21" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Grid.Row="1" Text="Pick a device, tune capture settings, and capture one-shot or timed snapshots." TextWrapping="Wrap" Foreground="#475569" FontSize="14" Margin="0,8,0,12" />

                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="1" Background="#0F172A0A" BorderBrush="#CBD5E1" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Image x:Name="PreviewImage"
                                       Grid.Column="0"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0" />

                                <StackPanel Grid.Column="1" Orientation="Vertical">
                                    <Border x:Name="DiagnosticBanner"
                                            Background="#FEF2F2"
                                            BorderBrush="#FECACA"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,10"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="DiagnosticText" Foreground="#991B1B" TextWrapping="Wrap" />
                                    </Border>

                                    <TextBlock Text="Capture controls" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#0F172A" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Camera" Width="95" VerticalAlignment="Center" />
                                        <ComboBox x:Name="CameraList" Width="190" Margin="0,0,0,10" SelectionChanged="OnCameraSelectionChanged" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Capture format" Width="95" VerticalAlignment="Center" />
                                        <ComboBox x:Name="FormatCombo" Width="190" Margin="0,0,0,10" SelectionChanged="FormatCombo_SelectionChanged">
                                            <ComboBoxItem Tag="jpg" Content="JPEG (.jpg)" IsSelected="True" />
                                            <ComboBoxItem Tag="png" Content="PNG (.png)" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Resolution" Width="95" VerticalAlignment="Center" />
                                        <ComboBox x:Name="ResolutionList" Width="190" Margin="0,0,0,10" SelectionChanged="ResolutionList_SelectionChanged">
                                            <ComboBoxItem Content="Auto" IsSelected="True" />
                                            <ComboBoxItem Content="1280 x 720" />
                                            <ComboBoxItem Content="1920 x 1080" />
                                            <ComboBoxItem Content="640 x 480" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Image quality" Width="95" VerticalAlignment="Center" />
                                        <Slider x:Name="QualitySlider" Minimum="10" Maximum="100" Value="90" Width="190" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="QualitySlider_ValueChanged" />
                                    </StackPanel>
                                    <TextBlock x:Name="QualityLabel" Text="Quality: 90" FontSize="11" Foreground="#64748B" Margin="0,0,0,8" />

                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="MirrorCheckBox" Content="Mirror preview" Margin="0,0,0,10" Checked="MirrorPreview_Changed" Unchecked="MirrorPreview_Changed" />
                                        <CheckBox x:Name="AutoStartCheckBox" Content="Auto-start preview on launch" Margin="8,0,0,0" Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed" />
                                    </StackPanel>
                                    <WrapPanel>
                                        <Button x:Name="RefreshButton" Content="Refresh Cameras" Click="RefreshButton_Click" Width="122" />
                                        <Button x:Name="StartButton" Content="Start Preview" Click="StartButton_Click" Width="122" />
                                        <Button x:Name="CaptureButton" Content="Capture Snapshot" Click="CaptureButton_Click" Width="148" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button x:Name="StopButton" Content="Stop Preview" Click="StopButton_Click" Width="122" />
                                        <Button x:Name="DiagnoseButton" Content="Run Diagnostics" Click="DiagnoseButton_Click" Width="132" Margin="8,0,0,0" />
                                        <CheckBox x:Name="TimedCaptureEnabledCheckBox" Content="Timed capture" VerticalAlignment="Center" Margin="8,4,0,0" Checked="TimedCaptureEnabledCheckBox_Checked" Unchecked="TimedCaptureEnabledCheckBox_Unchecked" />
                                        <TextBox x:Name="IntervalTextBox" Width="70" Text="5" Margin="8,0,0,0" VerticalContentAlignment="Center" />
                                        <TextBlock Text="sec" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </WrapPanel>
                                    <TextBlock x:Name="CaptureHint" TextWrapping="Wrap" Foreground="#475569" FontSize="12" Margin="0,8,0,0" Text="Tip: choose format + quality, then set interval + timed capture for automation." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ListBox x:Name="ActivityList" Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="18,0,0,0" Background="#F1F5F9">
                <StackPanel>
                    <TextBlock Text="Capture folder" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,14" />
                    <TextBlock x:Name="FolderText" Text="No folder set" Foreground="#475569" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="OpenFolderButton" Content="Open output folder" Click="OpenFolderButton_Click" Width="170" />
                        <Button x:Name="OpenFolderInExplorerButton" Content="Reveal in Explorer" Click="OpenFolderInExplorerButton_Click" Width="150" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="Recent captures" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                    <ListBox x:Name="CapturedFilesList" Height="250" BorderBrush="#CBD5E1" Margin="0,10,0,10" />
                    <Separator Margin="0,10,0,18" />
                    <TextBlock Text="Store readiness" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10" />
                    <TextBlock Text="This app is local-first by design: files stay on your PC until you choose cloud sync." TextWrapping="Wrap" Foreground="#475569" />
                    <TextBlock Text="Features now include auto-start setting, format/quality controls, and a first-run diagnostics fallback for camera setup." TextWrapping="Wrap" Foreground="#475569" />
                    <TextBlock Text="Store-Assets are preserved under repo-root for listing and privacy handoff." TextWrapping="Wrap" Foreground="#475569" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E2E8F0" Padding="18,10">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#334155" />
        </Border>
    </Grid>
</Window>
