<Window x:Class="SimpleWebcam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Webcam"
        Width="1120"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="#DB2777" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="FeatureText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DB2777" Padding="28,24">
            <StackPanel>
                <TextBlock Text="Simple Webcam" Foreground="White" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Preview camera devices and capture local snapshots." Foreground="#E0F2FE" FontSize="16" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Workflow" FontSize="21" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Grid.Row="1" Text="Select a camera, preview capture settings, and save snapshot notes." TextWrapping="Wrap" Foreground="#475569" FontSize="14" Margin="0,8,0,18" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel>
                    <Button Content="Refresh Cameras" Click="OnActionButtonClick" />
                    <Button Content="Preview Camera" Click="OnActionButtonClick" />
                    <Button Content="Capture Snapshot" Click="OnActionButtonClick" />
                        </WrapPanel>
                        <ListBox x:Name="ActivityList" Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,8,0,0" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" Padding="22" Margin="18,0,0,0">
                <StackPanel>
                    <TextBlock Text="Initial app scope" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,14" />
            <TextBlock Text="Camera selection surface" Style="{StaticResource FeatureText}" />
            <TextBlock Text="Preview/capture workflow" Style="{StaticResource FeatureText}" />
            <TextBlock Text="Device setting notes" Style="{StaticResource FeatureText}" />
            <TextBlock Text="Local media workflow" Style="{StaticResource FeatureText}" />
                    <Separator Margin="0,10,0,18" />
                    <TextBlock Text="Store readiness" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10" />
                    <TextBlock Text="Store-Assets includes listing draft, privacy text, and submission checklist. Package identity still needs the reserved Partner Center name before final MSIX upload." TextWrapping="Wrap" Foreground="#475569" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E2E8F0" Padding="18,10">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#334155" />
        </Border>
    </Grid>
</Window>